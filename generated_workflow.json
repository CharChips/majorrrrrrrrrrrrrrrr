{
    "workflow_name": "EV_Charging_Station_Site_Suitability_Pune",
    "workflow_type": "site_suitability",
    "reasoning": "To locate optimal new EV charging stations in Pune we prioritize proximity to major roads (road_network) to ensure easy access, high local demand (population_raster) to capture potential users, and low vegetation cover (vegetation_raster) to minimize site preparation and environmental impact. Each raster is normalized to a 0\u20111 scale, with the distance raster inverted so that closer distances receive higher scores. A weighted overlay combines the three criteria (road proximity 0.5, population density 0.3, low vegetation 0.2) to produce a suitability surface. The highest\u2011scoring pixels are then extracted as candidate site coordinates.",
    "steps": [
        {
            "step_id": 1,
            "tool": "DistanceRaster",
            "inputs": {
                "vector_layer": "road_network"
            },
            "parameters": {
                "output_resolution": "30m"
            },
            "outputs": {
                "raster": "distance_to_road"
            }
        },
        {
            "step_id": 2,
            "tool": "NormalizeRaster",
            "inputs": {
                "raster": "distance_to_road"
            },
            "parameters": {
                "method": "min_max"
            },
            "outputs": {
                "raster": "norm_distance"
            }
        },
        {
            "step_id": 3,
            "tool": "NormalizeRaster",
            "inputs": {
                "raster": "population_raster"
            },
            "parameters": {
                "method": "min_max"
            },
            "outputs": {
                "raster": "norm_population"
            }
        },
        {
            "step_id": 4,
            "tool": "NormalizeRaster",
            "inputs": {
                "raster": "vegetation_raster"
            },
            "parameters": {
                "method": "min_max"
            },
            "outputs": {
                "raster": "norm_vegetation"
            }
        },
        {
            "step_id": 5,
            "tool": "WeightedOverlay",
            "inputs": {
                "rasters": [
                    {
                        "raster": "norm_distance",
                        "weight": 0.5,
                        "invert": true
                    },
                    {
                        "raster": "norm_population",
                        "weight": 0.3,
                        "invert": false
                    },
                    {
                        "raster": "norm_vegetation",
                        "weight": 0.2,
                        "invert": true
                    }
                ]
            },
            "parameters": {
                "method": "sum"
            },
            "outputs": {
                "raster": "suitability_score"
            }
        },
        {
            "step_id": 6,
            "tool": "ExtractTopLocations",
            "inputs": {
                "suitability_raster": "suitability_score"
            },
            "parameters": {
                "top_n": 10,
                "output_format": "geojson"
            },
            "outputs": {
                "locations": "top_ev_charging_sites"
            }
        }
    ]
}