{
    "workflow_name": "Best EV Location",
    "workflow_type": "site_suitability",
    "reasoning": "This workflow identifies the best location for an Electric Vehicle (EV) charging station by evaluating site suitability based on proximity to charging infrastructure, population density, and accessibility. The workflow uses a raster-based approach to combine these criteria and extract the top locations.",
    "steps": [
        {
            "step_id": 1,
            "tool": "gdalwarp",
            "inputs": {
                "input_raster": "base_raster"
            },
            "parameters": {
                "dstSRS": "EPSG:4326"
            },
            "outputs": {
                "output_raster": "warped_raster"
            }
        },
        {
            "step_id": 2,
            "tool": "DistanceRaster",
            "inputs": {
                "vector_layer": "charging_infrastructure",
                "output_raster": "distance_raster"
            },
            "parameters": {},
            "outputs": {}
        },
        {
            "step_id": 3,
            "tool": "NormalizeRaster",
            "inputs": {
                "input_raster": "distance_raster",
                "output_raster": "normalized_distance_raster"
            },
            "parameters": {},
            "outputs": {}
        },
        {
            "step_id": 4,
            "tool": "overlay",
            "inputs": {
                "vector_layer": "population_density",
                "output_raster": "overlay_raster"
            },
            "parameters": {},
            "outputs": {}
        },
        {
            "step_id": 5,
            "tool": "NormalizeRaster",
            "inputs": {
                "input_raster": "overlay_raster",
                "output_raster": "normalized_overlay_raster"
            },
            "parameters": {},
            "outputs": {}
        },
        {
            "step_id": 6,
            "tool": "WeightedOverlay",
            "inputs": {
                "raster1": "warped_raster",
                "raster2": "normalized_distance_raster",
                "raster3": "normalized_overlay_raster",
                "output_raster": "suitability_raster"
            },
            "parameters": {
                "weights": "[0.3, 0.3, 0.4]"
            },
            "outputs": {}
        },
        {
            "step_id": 7,
            "tool": "NormalizeRaster",
            "inputs": {
                "input_raster": "suitability_raster",
                "output_raster": "normalized_suitability_raster"
            },
            "parameters": {},
            "outputs": {}
        },
        {
            "step_id": 8,
            "tool": "gdalwarp",
            "inputs": {
                "input_raster": "normalized_suitability_raster"
            },
            "parameters": {
                "dstSRS": "EPSG:4326"
            },
            "outputs": {
                "output_raster": "final_raster"
            }
        },
        {
            "step_id": 9,
            "tool": "ExtractTopLocations",
            "inputs": {
                "input_raster": "final_raster",
                "num_locations": "10"
            },
            "parameters": {},
            "outputs": {
                "output_locations": "best_locations"
            }
        }
    ]
}