{
    "workflow_name": "EV_Charging_Station_Suitability_Pune",
    "workflow_type": "site_suitability",
    "reasoning": "To locate EV charging stations in Pune we need sites that are close to major roads for accessibility, have high population density to ensure demand, and lie within commercially zoned areas where such infrastructure is permitted. Therefore we use the road_network raster to compute distance to the nearest road, the population_raster to capture demand, and the land_use_raster to isolate commercial zones. Each raster is normalized to a 0\u20111 scale (with distance inverted so that nearer pixels score higher) and then combined with a WeightedOverlay (weights: distance 0.4, population 0.4, land use 0.2). The resulting suitability surface is finally processed with ExtractTopLocations to return the top candidate points.",
    "steps": [
        {
            "step_id": 1,
            "tool": "DistanceRaster",
            "inputs": {
                "vector_layer": "road_network"
            },
            "parameters": {
                "output_name": "distance_to_road"
            },
            "outputs": {
                "raster": "distance_to_road"
            }
        },
        {
            "step_id": 2,
            "tool": "NormalizeRaster",
            "inputs": {
                "raster": "distance_to_road"
            },
            "parameters": {
                "invert": true,
                "output_name": "distance_norm"
            },
            "outputs": {
                "raster": "distance_norm"
            }
        },
        {
            "step_id": 3,
            "tool": "NormalizeRaster",
            "inputs": {
                "raster": "population_raster"
            },
            "parameters": {
                "output_name": "population_norm"
            },
            "outputs": {
                "raster": "population_norm"
            }
        },
        {
            "step_id": 4,
            "tool": "NormalizeRaster",
            "inputs": {
                "raster": "land_use_raster"
            },
            "parameters": {
                "reclassify_to_binary": {
                    "target_class": "commercial"
                },
                "output_name": "landuse_norm"
            },
            "outputs": {
                "raster": "landuse_norm"
            }
        },
        {
            "step_id": 5,
            "tool": "WeightedOverlay",
            "inputs": {
                "rasters": [
                    {
                        "raster": "distance_norm",
                        "weight": 0.4
                    },
                    {
                        "raster": "population_norm",
                        "weight": 0.4
                    },
                    {
                        "raster": "landuse_norm",
                        "weight": 0.2
                    }
                ]
            },
            "parameters": {
                "output_name": "suitability_score"
            },
            "outputs": {
                "raster": "suitability_score"
            }
        },
        {
            "step_id": 6,
            "tool": "ExtractTopLocations",
            "inputs": {
                "suitability_raster": "suitability_score"
            },
            "parameters": {
                "top_n": 10,
                "output_name": "ev_charging_candidates"
            },
            "outputs": {
                "vector": "ev_charging_candidates"
            }
        }
    ]
}