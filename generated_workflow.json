{
    "workflow_name": "EV Charging Station Location Finder",
    "workflow_type": "site_suitability",
    "steps": [
        {
            "step_id": 1,
            "tool": "gdalwarp",
            "inputs": {
                "input_raster": "base_raster"
            },
            "parameters": {
                "dstSRS": "EPSG:4326"
            },
            "outputs": {
                "output_raster": "warped_raster"
            }
        },
        {
            "step_id": 2,
            "tool": "DistanceRaster",
            "inputs": {
                "vector_layer": "roads_vector",
                "output_raster": "distance_raster"
            },
            "parameters": {},
            "outputs": {
                "distance_raster": "distance_raster"
            }
        },
        {
            "step_id": 3,
            "tool": "NormalizeRaster",
            "inputs": {
                "input_raster": "warped_raster"
            },
            "parameters": {},
            "outputs": {
                "normalized_raster": "normalized_raster"
            }
        },
        {
            "step_id": 4,
            "tool": "WeightedOverlay",
            "inputs": {
                "input_raster": "normalized_raster",
                "weight_raster": "distance_raster"
            },
            "parameters": {
                "weight_field": "distance"
            },
            "outputs": {
                "overlay_raster": "overlay_raster"
            }
        },
        {
            "step_id": 5,
            "tool": "NormalizeRaster",
            "inputs": {
                "input_raster": "overlay_raster"
            },
            "parameters": {},
            "outputs": {
                "normalized_overlay_raster": "normalized_overlay_raster"
            }
        },
        {
            "step_id": 6,
            "tool": "gdalwarp",
            "inputs": {
                "input_raster": "normalized_overlay_raster"
            },
            "parameters": {
                "dstSRS": "EPSG:4326"
            },
            "outputs": {
                "output_raster": "final_raster"
            }
        },
        {
            "step_id": 7,
            "tool": "NormalizeRaster",
            "inputs": {
                "input_raster": "final_raster"
            },
            "parameters": {},
            "outputs": {
                "normalized_final_raster": "normalized_final_raster"
            }
        },
        {
            "step_id": 8,
            "tool": "WeightedOverlay",
            "inputs": {
                "input_raster": "normalized_final_raster",
                "weight_raster": "distance_raster"
            },
            "parameters": {
                "weight_field": "distance"
            },
            "outputs": {
                "overlay_raster": "overlay_raster"
            }
        },
        {
            "step_id": 9,
            "tool": "NormalizeRaster",
            "inputs": {
                "input_raster": "overlay_raster"
            },
            "parameters": {},
            "outputs": {
                "normalized_overlay_raster": "normalized_overlay_raster"
            }
        },
        {
            "step_id": 10,
            "tool": "ExtractTopLocations",
            "inputs": {
                "input_raster": "normalized_overlay_raster"
            },
            "parameters": {
                "num_locations": 10
            },
            "outputs": {
                "location_coordinates": "location_coordinates"
            }
        }
    ]
}